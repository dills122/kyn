{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "kyn",
          "informationUri": "https://github.com/",
          "rules": [
            {
              "id": "story-sync",
              "shortDescription": {
                "text": "Story was not updated."
              },
              "fullDescription": {
                "text": "Story was not updated."
              },
              "properties": {
                "familyId": "angular-component"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "story-sync",
          "level": "error",
          "message": {
            "text": "Story was not updated. (family instance: libs/ui/button/button)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "libs/ui/button/button.component.ts"
                }
              },
              "message": {
                "text": "changed file"
              }
            }
          ],
          "relatedLocations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "libs/ui/button/button.stories.ts"
                }
              },
              "message": {
                "text": "expected related file"
              }
            }
          ],
          "properties": {
            "expectedFiles": [
              "libs/ui/button/button.stories.ts"
            ],
            "familyId": "angular-component",
            "familyName": "libs/ui/button/button",
            "severity": "error",
            "status": "fail"
          }
        }
      ]
    }
  ]
}
